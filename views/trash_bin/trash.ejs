<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Starred</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f1f3f4;
}

.container{
    width:95%;
    max-width:1300px;
    margin:30px auto;
}

.header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.header h2{
    color:#202124;
    font-size:28px;
}

.total{
    color:#5f6368;
    font-size:15px;
}

.mail-box{
    background:#fff;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 2px 12px rgba(0,0,0,.08);
}

.mail{
    display:grid;
    grid-template-columns:250px 1fr 120px 120px;
    align-items:center;
    padding:18px 25px;
    border-bottom:1px solid #ececec;
    cursor:pointer;
    transition:.2s;
}

.mail:hover{
    background:#f8f9fa;
}

.mail:last-child{
    border-bottom:none;
}

.sender{
    font-weight:600;
    color:#202124;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
}

.subject{
    overflow:hidden;
    white-space:nowrap;
    text-overflow:ellipsis;
    color:#202124;
}

.preview{
    color:#70757a;
    font-size:14px;
}

.star{
    text-align:center;
    color:#fbbc04;
    font-size:20px;
}

.date{
    text-align:right;
    color:#5f6368;
    font-size:14px;
}

.empty{
    padding:80px;
    text-align:center;
    color:#777;
    font-size:20px;
}

@media(max-width:900px){

.mail{
    grid-template-columns:1fr;
    gap:10px;
}

.star,
.date{
    text-align:left;
}

}
</style>

</head>
<body>

<div class="container">

    <div class="header">
        <h2>⭐ Trash_bin</h2>

        <div class="total">
            Total : <%= user.inbox.length %>
        </div>
    </div>

    <div class="mail-box">

    <% if(user.inbox.length === 0){ %>

        <div class="empty">
            No starred mails found.
        </div>

    <% } else { %>

        <% user.inbox.forEach(function(mail){ %>

        <div class="mail" onclick="window.location='/indexroute/trash_bin/<%= mail.id%>'">

            <div class="sender">
                From :
                <%= mail.from.firstname %> <%= mail.from.surname %>
            </div>

            <div class="subject">
                <strong><%= mail.subject %></strong>

                <% if(mail.message){ %>

                <span class="preview">
                    - <%= mail.message.substring(0,80) %><%= mail.message.length > 80 ? "..." : "" %>
                </span>

                <% } %>

            </div>

            <div class="star">
                ★
            </div>

            <div class="date">
                <%= new Date(mail.createdAt).toLocaleDateString() %>
            </div>

        </div>

        <% }) %>

    <% } %>

    </div>

</div>
<%- include('../partial/toaster') %>
</body>
</html>