<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  
 <link rel="stylesheet" href="../stylesheets/profile/profilepic.css">
<style>
    *{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f6f8fc;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.account-card{
    width:360px;
    background:#fff;
    border-radius:28px;
    box-shadow:0 6px 20px rgba(0,0,0,.18);
    padding:30px 25px;
    text-align:center;
}
.avatar,
.avatar-letter{
    width:45px;
    height:45px;
    border-radius:50%;
}

.avatar{
    object-fit:cover;
}

.avatar-letter{
    display:flex;
    justify-content:center;
    align-items:center;

    background:#4285f4;
    color:#fff;

    font-size:20px;
    font-weight:bold;
}

.email{
    font-size:15px;
    color:#5f6368;
    margin-bottom:20px;
}

.profile{
    margin-bottom:18px;
    display:flex;
    justify-content:center;
    transition:transform .2s;
    cursor:pointer;
}

.profile:hover{
    transform:scale(1.05);
}

.profile img{
    width:90px;
    height:90px;
    border-radius:50%;
    object-fit:cover;
}

.greeting{
    font-size:26px;
    color:#202124;
    margin-bottom:15px;
}

.manage-btn{
    display:inline-block;
    text-decoration:none;
    color:#1a73e8;
    border:1px solid #dadce0;
    border-radius:25px;
    padding:10px 22px;
    font-size:14px;
    font-weight:500;
    margin-bottom:25px;
    transition:.2s;
}

.manage-btn:hover{
    background:#f1f3f4;
}

.accounts{
    display:flex;
    flex-direction:column;
    gap:10px;
}

.accounts a{
    text-decoration:none;
    color:#202124;
    background:#f8f9fa;
    padding:12px 18px;
    border-radius:15px;
    transition:.2s;
    font-size:15px;
}

.accounts a:hover{
    background:#e8eaed;
}
</style>
 
</head>
<body>

    <div class="account-card">

    <div class="email">
        <%= user.email %>
    </div>

    
    <div class="profile" onclick="window.location='/indexroute/profileupdate/<%= user.id %>'">
        
        <% if (user.image) { %>

        <img
            class="profile-img"
            src="data:<%= user.imageType %>;base64,<%= user.image %>"
            alt="Profile Picture">

        <% } else { %>

        <div class="avatar-letter">
            <%= user.firstname.charAt(0).toUpperCase() %>
        </div>

        <% } %>
    </div>

    <h2 class="greeting">
        Hi, <%= user.firstname%> <%= user.lastname %>
    </h2>

    <a href="#" class="manage-btn">
        Manage your Google Account
    </a>

    <div class="accounts">
        <a href="#">Account 1</a>
        <a href="#">Account 2</a>
        <a href="#">Account 3</a>
        <a href="#">Account 4</a>
    </div>

</div>
  
  
</body>
</html>